# Kopiera till .env och fyll i från Supabase-projektets inställningar (API).
# Utan dessa körs appen i LOKALT LÄGE (all data sparas bara i webbläsaren).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ANTHROPIC_API_KEY sätts ALDRIG här — endast som secret i Supabase Edge Functions:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
